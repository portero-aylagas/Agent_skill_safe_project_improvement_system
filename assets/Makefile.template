.PHONY: verify test compile lint

PYTHON ?= python3

verify: compile lint test

test:
	@if [ -d tests ]; then \
		$(PYTHON) -c "import pytest" >/dev/null 2>&1 || { \
			echo "pytest is required because tests/ exists."; \
			echo "Add pytest to the project's dev/test dependencies, then rerun make verify."; \
			exit 1; \
		}; \
		$(PYTHON) -m pytest -q; \
	else \
		echo "No tests directory found; skipping pytest."; \
	fi

compile:
	@$(PYTHON) -m compileall -q -x '(^|/)(\.venv|venv|\.conda|__pycache__|\.git|build|dist)/' .

lint:
	@$(PYTHON) -c "import ruff" >/dev/null 2>&1 || { \
		echo "ruff is required. Install it with: python -m pip install ruff"; \
		exit 1; \
	}
	@$(PYTHON) -m ruff check .
